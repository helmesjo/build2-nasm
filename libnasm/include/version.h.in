// # This defines the following macros:
// #
// # version.h:
// # NASM_MAJOR_VER
// # NASM_MINOR_VER
// # NASM_SUBMINOR_VER       -- this is zero if no subminor
// # NASM_PATCHLEVEL_VER     -- this is zero if no patchlevel
// # NASM_SNAPSHOT           -- if snapshot
// # NASM_VERSION_ID         -- version number encoded
// # NASM_VER                -- whole version number as a string

#define NASM_MAJOR_VER       $libnasm.version.major$
#define NASM_MINOR_VER       $libnasm.version.minor$
#define NASM_SUBMINOR_VER    0
#define NASM_PATCHLEVEL_VER  $libnasm.version.patch$
#define NASM_SNAPSHOT        $libnasm.version.snapshot_sn$ULL
#define NASM_VERSION_ID      "$libnasm.version.snapshot_id$"
#define NASM_VER             "$libnasm.version.project$"
